{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre8.pw/schemas/ui-page-contract.schema.json",
  "title": "CRE8UiPageContract",
  "type": "object",
  "required": [
    "page_id",
    "sprint",
    "url",
    "method",
    "persona",
    "purpose",
    "required_fields",
    "api_calls",
    "success_ux",
    "error_ux",
    "figma_data"
  ],
  "additionalProperties": false,
  "properties": {
    "page_id": {"type": "string", "pattern": "^[a-z0-9_]+_v[0-9]+$"},
    "sprint": {"type": "string", "pattern": "^S[0-9]+$"},
    "url": {"type": "string", "pattern": "^/.*"},
    "method": {"type": "string", "enum": ["GET", "POST", "PUT", "PATCH", "DELETE"]},
    "persona": {"type": "array", "items": {"type": "string"}, "minItems": 1, "uniqueItems": true},
    "purpose": {"type": "string", "minLength": 5},
    "required_fields": {"type": "array", "items": {"$ref": "#/$defs/requiredField"}},
    "api_calls": {"type": "array", "items": {"$ref": "#/$defs/apiCall"}, "minItems": 1},
    "success_ux": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "error_ux": {"type": "array", "items": {"type": "string"}, "minItems": 1},
    "figma_data": {"type": "object", "additionalProperties": true},
    "friendly_ui_description": {"type": "object", "additionalProperties": true},
    "acceptance_criteria": {"type": "array", "items": {"type": "string"}},
    "route_states": {"type": "array", "items": {"type": "string"}, "uniqueItems": true}
  },
  "$defs": {
    "requiredField": {
      "type": "object",
      "required": ["name", "type", "required"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string"},
        "type": {"type": "string"},
        "required": {"type": "boolean"}
      }
    },
    "apiCall": {
      "type": "object",
      "required": ["name", "method", "endpoint", "success_statuses"],
      "additionalProperties": true,
      "properties": {
        "name": {"type": "string"},
        "method": {"type": "string"},
        "endpoint": {"type": "string", "pattern": "^/.*"},
        "success_statuses": {"type": "array", "items": {"type": "integer"}, "minItems": 1}
      }
    }
  }
}
