{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://cre8.local/schemas/error-envelope.schema.json",
  "title": "ErrorEnvelope",
  "type": "object",
  "required": ["error", "meta"],
  "properties": {
    "error": {
      "type": "object",
      "required": ["code", "message", "request_id"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "details": { "type": ["array", "object", "null"] },
        "request_id": { "type": "string" }
      },
      "additionalProperties": true
    },
    "meta": {
      "type": "object",
      "required": ["request_id", "timestamp_utc"],
      "properties": {
        "request_id": { "type": "string" },
        "timestamp_utc": { "type": "string", "format": "date-time" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}
